<UserControl x:Class="AgenciasMantenimiento" Name="AgenciasMantenimiento"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:controles="clr-namespace:ControlesUsuario;assembly=ControlesUsuario"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <xctk:BusyIndicator IsBusy="{Binding EstaOcupado}" BusyContent="Espere, por favor...">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Mantenimiento de agencias de transporte"
                           FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <controles:SelectorEmpresa Configuracion="{Binding configuracion}"
                                           Seleccionada="{Binding empresaSeleccionada, Mode=TwoWay}"
                                           Etiqueta="Empresa:" HorizontalAlignment="Left"/>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding AgenciasFiltradas}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nº" Binding="{Binding Numero}" Width="50"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="140"/>
                    <DataGridTextColumn Header="Ruta" Binding="{Binding Ruta}" Width="60"/>
                    <DataGridTextColumn Header="Identificador" Binding="{Binding Identificador}" Width="*"/>
                    <DataGridTextColumn Header="Prefijo cód. barras" Binding="{Binding PrefijoCodigoBarras}" Width="120"/>
                    <DataGridTextColumn Header="Cta. reembolsos" Binding="{Binding CuentaReembolsos}" Width="120">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="ToolTip" Value="Admite formato abreviado con punto: 555.20 → 55500020"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Fuel (%)"
                                        Binding="{Binding PorcentajeFuel, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                        Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridCheckBoxColumn Header="Cuarentena" Binding="{Binding EnCuarentena, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Nueva agencia" Command="{Binding NuevaAgenciaCommand}"
                        Width="120" Height="30" Margin="0,0,10,0"/>
                <Button Content="Guardar" Command="{Binding GuardarCommand}"
                        Width="120" Height="30"/>
            </StackPanel>
        </Grid>
    </xctk:BusyIndicator>
</UserControl>

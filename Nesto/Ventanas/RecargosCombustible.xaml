<UserControl x:Class="RecargosCombustible" Name="RecargosCombustible"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <xctk:BusyIndicator IsBusy="{Binding EstaOcupado}" BusyContent="Espere, por favor...">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Recargo de combustible (fuel) por agencia"
                       FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Agencias}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nº" Binding="{Binding Numero}" IsReadOnly="True" Width="60"/>
                    <DataGridTextColumn Header="Agencia" Binding="{Binding Nombre}" IsReadOnly="True" Width="*"/>
                    <DataGridTextColumn Header="Fuel (%)"
                                        Binding="{Binding PorcentajeFuel, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Button Grid.Row="2" Content="Guardar" Command="{Binding GuardarCommand}"
                    HorizontalAlignment="Right" Width="120" Height="30" Margin="0,10,0,0"/>
        </Grid>
    </xctk:BusyIndicator>
</UserControl>

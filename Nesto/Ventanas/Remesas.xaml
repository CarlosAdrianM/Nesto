<UserControl x:Class="Remesas" Name="Remesas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:controles="clr-namespace:ControlesUsuario;assembly=ControlesUsuario"
    xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
    xmlns:local="clr-namespace:Nesto.Views"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <!-- #3: total en € por grupo (fecha de cargo) en la cabecera del detalle -->
        <local:SumaImporteGrupoConverter x:Key="sumaImporteGrupo"/>
    </UserControl.Resources>

    <xctk:BusyIndicator IsBusy="{Binding estaOcupado}" BusyContent="Espere, por favor...">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="15*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" Margin="3" ItemsSource="{Binding listaEmpresas}" DisplayMemberPath="Nombre" SelectedValuePath="Numero" SelectedValue="{Binding empresaActual}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding mensajeError}" Foreground="Red" TextAlignment="Center" VerticalAlignment="Center" TextWrapping="WrapWithOverflow" Margin="3"/>
            </Grid>
            <TabControl Grid.Row="2" TabStripPlacement="Top" SelectedItem="{Binding PestañaSeleccionada}">
                <!-- Nesto#424: primera pestaña y renombrada a "Cartera viva" — el orden de las
                     pestañas sigue la vida del efecto: cartera viva → remesa → impagados -->
                <TabItem Name="tabCrearRemesa" Header="Cartera viva">
                    <!-- NestoAPI#332: candidatos preseleccionados por el servidor (gating de
                         entrega #172 y puerta de neteo incluidos); el usuario marca/desmarca
                         y crea. El servidor revalida TODO en el POST. -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="3">
                            <StackPanel Orientation="Horizontal">
                                <!-- NestoAPI#345: hasta qué vencimiento se cargan candidatos.
                                     Default: propuesta del servidor (hoy + DiasAntelacionRemesa
                                     del usuario, saltando fines de semana y festivos) -->
                                <TextBlock Text="Efectos vencidos hasta el" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <DatePicker SelectedDate="{Binding FechaSeleccionHasta}" VerticalAlignment="Center" Margin="0,0,10,0"
                                            ToolTip="Se incluyen los efectos con vencimiento hasta esta fecha (los de fecha de hoy siguen fuera)"/>
                                <Button Content="Cargar _candidatos" Command="{Binding CargarCandidatosCommand}" Padding="8,2"/>
                                <Button Content="Marcar _todos" Command="{Binding MarcarTodosCommand}" Padding="8,2" Margin="10,0,0,0"
                                        ToolTip="Marca todos los efectos que el servidor propone (los retenidos en gris se marcan uno a uno)"/>
                                <Button Content="_Desmarcar todos" Command="{Binding DesmarcarTodosCommand}" Padding="8,2" Margin="5,0,0,0"/>
                                <TextBlock Text="Banco:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                <!-- Nesto#425: combo con el nombre del banco (guarda el código en BancoRemesa) -->
                                <controles:SelectorBanco Width="180" VerticalAlignment="Center"
                                                         Empresa="{Binding empresaActual}"
                                                         Seleccionado="{Binding BancoRemesa, Mode=TwoWay}"
                                                         VisibilidadEtiqueta="Collapsed"/>
                                <Button Content="Crear _remesa" Command="{Binding CrearRemesaCommand}" Padding="8,2" Margin="15,0,0,0" FontWeight="Bold"/>
                                <!-- #1: TextBox de solo lectura (no TextBlock) para poder seleccionar
                                     y copiar el total con Ctrl+C o botón derecho (texto plano) -->
                                <TextBox VerticalAlignment="Center" Margin="20,0,0,0" IsReadOnly="True"
                                         BorderThickness="0" Background="Transparent" FontWeight="Bold"
                                         Cursor="IBeam" IsTabStop="False"
                                         Text="{Binding ResumenSeleccionado, Mode=OneWay}"
                                         ToolTip="Seleccione y copie el total (Ctrl+C o botón derecho)"/>
                            </StackPanel>
                            <!-- NestoAPI#345: fechas de cargo de la remesa -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <CheckBox Content="Respetar el vencimiento de cada efecto (un cargo al banco por fecha; los vencidos se cobran hoy)"
                                          VerticalAlignment="Center" IsChecked="{Binding RespetarVencimientos}"/>
                                <TextBlock Text="Fecha de cargo única:" VerticalAlignment="Center" Margin="20,0,5,0"/>
                                <DatePicker SelectedDate="{Binding FechaCargo}" IsEnabled="{Binding ForzarFechaUnica}"
                                            VerticalAlignment="Center"
                                            ToolTip="Todos los efectos se cargan en esta fecha (default hoy; nunca anterior a hoy). Con la casilla marcada no aplica."/>
                            </StackPanel>
                        </StackPanel>
                        <!-- #2: doble clic en un efecto (naranja/con negativos) abre el Extracto
                             de Cliente cargado con ese cliente para liquidar -->
                        <DataGrid Grid.Row="1" Name="gridCandidatos" ItemsSource="{Binding ListaCandidatos}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" ColumnWidth="Auto" SelectionMode="Single"
                                  MouseDoubleClick="GridCandidatos_MouseDoubleClick"
                                  ToolTip="Doble clic en un efecto para abrir el Extracto del cliente y liquidar">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Incluir" Binding="{Binding Seleccionado, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Efecto" Binding="{Binding Efecto}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Vencimiento" Binding="{Binding Vencimiento, StringFormat=d}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Importe" Binding="{Binding ImportePendiente, StringFormat=c}" IsReadOnly="True">
                                    <DataGridTextColumn.CellStyle>
                                        <Style>
                                            <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="CCC" Binding="{Binding Ccc}" IsReadOnly="True"/>
                                <DataGridCheckBoxColumn Header="Negativos" Binding="{Binding ClienteConNegativos, Mode=OneWay}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Motivo" Binding="{Binding Motivo}" Width="*" IsReadOnly="True"/>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Preseleccionado}" Value="False">
                                            <Setter Property="Foreground" Value="Gray"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ClienteConNegativos}" Value="True">
                                            <Setter Property="Foreground" Value="DarkOrange"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Name="tabRemesas" Header="Remesas">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.Resources>
                            <!-- NestoAPI#353: el detalle se agrupa por fecha de cargo (remesas
                                 multi-vencimiento #345), igual que el informe impreso -->
                            <CollectionViewSource x:Key="MovimientosAgrupados" Source="{Binding listaMovimientos}">
                                <CollectionViewSource.SortDescriptions>
                                    <scm:SortDescription PropertyName="Fecha"/>
                                    <scm:SortDescription PropertyName="Número"/>
                                </CollectionViewSource.SortDescriptions>
                                <CollectionViewSource.GroupDescriptions>
                                    <PropertyGroupDescription PropertyName="Fecha"/>
                                </CollectionViewSource.GroupDescriptions>
                            </CollectionViewSource>
                        </Grid.Resources>
                        <DockPanel Grid.Column="0" Grid.Row="0">
                            <Button DockPanel.Dock="Bottom" Content="Ver _Todas" Command="{Binding cmdVerTodasLasRemesas}" />
                            <DataGrid DockPanel.Dock="Top" ItemsSource="{Binding listaRemesas}" SelectedItem="{Binding remesaActual}" IsReadOnly="True" AutoGenerateColumns="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" ColumnWidth="*"  CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Número" Binding="{Binding Numero}" />
                                    <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=d}"/>
                                    <DataGridTextColumn Header="Importe" Binding="{Binding Importe, StringFormat=c}">
                                        <DataGridTextColumn.CellStyle>
                                            <Style>
                                                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right" />
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Banco" Binding="{Binding Banco}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                        </DockPanel>
                        <DataGrid Name="gridDetalleRemesa" Grid.Column="1" Grid.Row="0" ItemsSource="{Binding Source={StaticResource MovimientosAgrupados}, NotifyOnTargetUpdated=True}" Binding.TargetUpdated="GridDetalleRemesa_TargetUpdated" AutoGenerateColumns="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" ColumnWidth="*" CanUserAddRows="False">
                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Background="#FFEEEEEE">
                                                <TextBlock FontWeight="Bold" Margin="3" Text="{Binding Name, StringFormat='Fecha de cargo: {0:dd/MM/yyyy}'}"/>
                                                <!-- #3: además del nº de efectos, el importe total del grupo -->
                                                <TextBlock FontWeight="Bold" Margin="0,3,3,3">
                                                    <Run Text="("/><Run Text="{Binding ItemCount, Mode=OneWay}"/><Run Text=" efectos - "/><Run Text="{Binding Items, Converter={StaticResource sumaImporteGrupo}, Mode=OneWay}"/><Run Text=")"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </DataGrid.GroupStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Número" Binding="{Binding Número}" />
                                <DataGridTextColumn Header="Contacto" Binding="{Binding Contacto}" />
                                <DataGridTextColumn Header="Nº Documento" Binding="{Binding Nº_Documento}" />
                                <DataGridTextColumn Header="Efecto" Binding="{Binding Efecto}" />
                                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=d}" />
                                <DataGridTextColumn Header="Concepto" Binding="{Binding Concepto}" Width="3*" />
                                <DataGridTextColumn Header="Importe" Binding="{Binding Importe, StringFormat=c}">
                                    <DataGridTextColumn.CellStyle>
                                        <Style>
                                            <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right" />
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="CCC" Binding="{Binding CCC}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <DockPanel Grid.Row="1" Grid.ColumnSpan="2" >
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <ComboBox ItemsSource="{Binding listaTiposRemesa}" SelectedItem="{Binding tipoRemesaActual}" DisplayMemberPath="descripcion"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <Label Content="Fecha de Cobro: " />
                                    <DatePicker Text="{Binding fechaCobro, Mode=TwoWay}"/>
                                </StackPanel>

                                <Button Grid.Row="1" Grid.Column="0" Content="Crear Fichero SEPA" Command="{Binding cmdCrearFicheroRemesa}" Margin="0,3,3,3" />
                                <!-- NestoAPI#353: informe de la remesa seleccionada (QuestPDF en el backend) -->
                                <Button Grid.Row="1" Grid.Column="1" Content="Imprimir Remesa" Command="{Binding ImprimirRemesaCommand}" Margin="3,3,0,3" />

                            </Grid>

                        </DockPanel>
                    </Grid>
                </TabItem>
                <TabItem Name="tabImpagados" Header="Impagados">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <DockPanel Grid.Column="0" Grid.Row="0">
                            <DataGrid DockPanel.Dock="Top" ItemsSource="{Binding listaImpagados}" SelectedItem="{Binding impagadoActual}" IsReadOnly="True" AutoGenerateColumns="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" ColumnWidth="*"  CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Asiento" Binding="{Binding asiento}" />
                                    <DataGridTextColumn Header="Fecha" Binding="{Binding fecha, StringFormat=d}" />
                                    <DataGridTextColumn Header="Nº Movimientos" Binding="{Binding cuenta}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                        <DataGrid Grid.Column="1" Grid.Row="0" ItemsSource="{Binding listaImpagadosDetalle}" AutoGenerateColumns="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" ColumnWidth="*" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Número" Binding="{Binding Número}" />
                                <DataGridTextColumn Header="Contacto" Binding="{Binding Contacto}" />
                                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=d}" />
                                <DataGridTextColumn Header="Nº Documento" Binding="{Binding Nº_Documento}" />
                                <DataGridTextColumn Header="Efecto" Binding="{Binding Efecto}" />
                                <DataGridTextColumn Header="Concepto" Binding="{Binding Concepto}" Width="4*" />
                                <DataGridTextColumn Header="Importe" Binding="{Binding Importe, StringFormat=c}">
                                    <DataGridTextColumn.CellStyle>
                                        <Style>
                                            <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right" />
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Importe Pdte." Binding="{Binding ImportePdte, StringFormat=c}">
                                    <DataGridTextColumn.CellStyle>
                                        <Style>
                                            <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right" />
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Fecha Vto." Binding="{Binding FechaVto, StringFormat=d}" />
                                <DataGridTextColumn Header="Ruta" Binding="{Binding Ruta}" />
                                <DataGridTextColumn Header="Vendedor" Binding="{Binding Vendedor}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <DockPanel Grid.Row="1" Grid.ColumnSpan="2" >
                            <StackPanel>
                                <Button Content="Leer Impagados" Command="{Binding cmdLeerFicheroImpagado}" Margin="3"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <!-- Nesto#340 Fase 1C.14 slice 8: eliminado el botón "Crear Tareas Outlook"
                                             (bindeaba a un comando comentado desde hace años: no hacía nada) -->
                                        <Button Grid.Column="0" Content="Crear Tareas Planner" Command="{Binding CrearTareasPlannerCommand}" Margin="3" Padding="3"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding usuarioTareas}" Margin="3" VerticalContentAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </xctk:BusyIndicator>

</UserControl>

<UserControl x:Class="MenuBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Nesto.ViewModels;assembly=ViewModels"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">

    <UserControl.Resources>

        <DataTemplate x:Key="RatiosTemplateRojo">
            <StackPanel>
                <Border BorderThickness="2" Width ="200" BorderBrush="Red" CornerRadius="5" Padding="1"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center" Height="20" Margin="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Nombre}"
                       FontSize="8" HorizontalAlignment="Left" VerticalAlignment="Center"
                       Grid.Column="0"/>
                        <TextBlock Text="{Binding Ratio,StringFormat=p}" Name="txtRatio"
                       FontSize="8" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="2" Foreground="Red"/>
                        <Image Source="/Images/FlechaRoja.png" Grid.Column="1"></Image>
                    </Grid>
                </Border>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="RatiosTemplateVerde">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border BorderThickness="2" Width ="200" BorderBrush="Green" CornerRadius="5" Padding="1"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center" Height="20" Margin="1" Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Nombre}"
                       FontSize="8" HorizontalAlignment="Left"
                       Grid.Column="0"/>
                        <TextBlock Text="{Binding Ratio,StringFormat=p}" Name="txtRatio"
                       FontSize="8" FontWeight="Bold" HorizontalAlignment="Right" Grid.Column="2" Foreground="Green"/>
                        <Image Source ="/Images/FlechaVerde.png" Grid.Column="1"></Image>
                    </Grid>
                </Border>

            </Grid>
        </DataTemplate>

        <vm:RatioDataTemplateSelector x:Key="myDataTemplateSelector"/>

        <vm:IconoConverter x:Key="iconoConverter"/>

    </UserControl.Resources>


    <Ribbon x:Name="MainMenu" x:FieldModifier="Protected Friend">
        <Ribbon.ApplicationMenu>
            <RibbonApplicationMenu Label="Nesto">
                <RibbonApplicationMenu.ControlSizeDefinition>
                    <RibbonControlSizeDefinition IsLabelVisible="True" />
                </RibbonApplicationMenu.ControlSizeDefinition>
                <RibbonApplicationMenuItem Header="Parámetros" KeyTip="P" Command="{Binding ParametrosCommand}" />
            </RibbonApplicationMenu>
        </Ribbon.ApplicationMenu>
        <RibbonTab x:Name="tabClientes"
                              Header="Clientes">
            <RibbonGroup x:Name="grpClientesMantenimiento"
                                    Header="Mantenimiento">
                <RibbonButton Label="Ficha" LargeImageSource="/Images/Cliente.png" Command="{Binding ClientesFichaCommand}" />
                <RibbonButton Label="Alquileres" LargeImageSource="/Images/Cliente.png" Command="{Binding ClientesAlquileresCommand}" />
                <RibbonButton Label="Remesas" LargeImageSource="/Images/Cliente.png" Command="{Binding ClientesRemesasCommand}" />
                <RibbonButton Label="Agencias" LargeImageSource="/Images/Cliente.png" Command="{Binding ClientesAgenciasCommand}" />
            </RibbonGroup>
        </RibbonTab>

        <RibbonTab x:Name="tabVendedores"
                              Header="Vendedores">
            <RibbonGroup x:Name="grpVendedoresCliente" Header="Clientes">
                <RibbonButton Label="Ficha" LargeImageSource="/Images/Cliente.png" Command="{Binding VendedoresClientesCommand}" />
                <RibbonButton Label="Planes de Ventajas" LargeImageSource="/Images/Cliente.png" Command="{Binding VendedoresPlanVentajasCommand}" />
            </RibbonGroup>
            <RibbonGroup x:Name="grpVendedoresComisiones" Header="Comisiones">
                <RibbonButton Label="Comisiones" LargeImageSource="/Images/Cliente.png" Command="{Binding VendedoresComisionesCommand}" />
            </RibbonGroup>
        </RibbonTab>

        <RibbonTab x:Name="tabHerramientas"
                              Header="Herramientas">
            <RibbonGroup x:Name="grpPrestashop"
                                    Header="Mantenimiento">

                <RibbonButton Label="Prestashop" LargeImageSource="/Images/Prestashop.png" Command="{Binding PrestashopCommand}" />
            </RibbonGroup>
            <RibbonGroup x:Name="grpVideos"
                                    Header="Contenido" Visibility="{Binding VideosVisible}">
                <RibbonButton Label="Videos" LargeImageSource="/Images/Prestashop.png" Command="{Binding VideosCommand}" />
            </RibbonGroup>
        </RibbonTab>

        <RibbonTab x:Name="tabInformes"
                              Header="Informes">
            <RibbonGroup  Name="grpTelefono" Header="Vendedores Teléfono">
                <RibbonButton Label="Rapport" LargeImageSource="/Images/rapports.png" Visibility="{Binding RapportVisible}" Command="{Binding RapportCommand}" />
            </RibbonGroup>

            <RibbonGroup x:Name="grpGrupoEmpresas"
                                    Header="Grupo de Empresas">
                <RibbonButton Label="Ventas" HorizontalAlignment="Center" LargeImageSource="/Icono2_NV_256x256.ico" Visibility="{Binding VentasEmpresasVisible}" Command="{Binding VentasEmpresasCommand}" />
            </RibbonGroup>
            <RibbonGroup x:Name="grpControles"
                                    Header="Informes de Control">
                <RibbonButton Label="Pedidos" LargeImageSource="/Images/ControlPedidos.png" Command="{Binding ControlPedidosCommand}" />
            </RibbonGroup>

            <RibbonGroup x:Name="grpInventarios"
                                    Header="Inventario">
                <RibbonButton Label="Inventario" LargeImageSource="/Images/Inventario.png" Command="{Binding InventarioCommand}" />
            </RibbonGroup>

            <RibbonGroup x:Name="grpAlmacen" Header="Almacén" Visibility="{Binding AlmacenVisible}" >
                <RibbonButton Label="Picking" LargeImageSource="/Images/Picking.png" Command="{Binding PickingCommand}" />
                <RibbonButton Label="Packing" LargeImageSource="/Images/Packing.png" Command="{Binding PackingCommand}" />
            </RibbonGroup>

            <RibbonGroup x:Name="grpRatio"
                                    Header="Ratios">
                <RibbonButton Label="Premio Deuda" LargeImageSource="/Images/Premios.png" Command="{Binding RatioDeudaCommand}" />
            </RibbonGroup>

            <RibbonGroup x:Name="grpFechas" Header="Fechas">
                <StackPanel>
                    <RibbonComboBox VerticalAlignment="Top" HorizontalAlignment="Stretch">
                        <RibbonGallery SelectedValue="{Binding OpcionesFechas}" SelectedValuePath="Content"
                              MaxColumnCount="1">
                            <RibbonGalleryCategory>
                                <RibbonGalleryItem Content="Actual"/>
                                <RibbonGalleryItem Content="Anterior" />
                                <RibbonGalleryItem Content="Personalizar"/>
                            </RibbonGalleryCategory>
                        </RibbonGallery>
                    </RibbonComboBox>
                    <StackPanel Visibility="{Binding MostrarFechas}">
                        <DatePicker Text="{Binding FechaInformeInicial, Mode=TwoWay}"></DatePicker>
                        <DatePicker Text="{Binding FechaInformeFinal, Mode=TwoWay}"></DatePicker>
                    </StackPanel>
                </StackPanel>
            </RibbonGroup>

        </RibbonTab>

    </Ribbon>
</UserControl>

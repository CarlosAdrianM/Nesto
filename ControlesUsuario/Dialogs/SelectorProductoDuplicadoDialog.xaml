<UserControl x:Class="ControlesUsuario.Dialogs.SelectorProductoDuplicadoDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             MinWidth="420" MinHeight="320">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Este código de barras corresponde a varios productos. Elija el que desea añadir:"/>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Candidatos}"
                 SelectedItem="{Binding Seleccionado, Mode=TwoWay}"
                 MouseDoubleClick="ListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding Producto}" FontWeight="Bold" Width="80"/>
                        <TextBlock Text="{Binding Nombre}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Aceptar" Command="{Binding AceptarCommand}" Width="80" Margin="0,0,10,0"
                    IsDefault="True"/>
            <Button Content="Cancelar" Command="{Binding CancelarCommand}" Width="80"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="Nesto.Modulos.CanalesExternos.Views.CanalesExternosFacturasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000" Language="es-ES">
    <xctk:BusyIndicator IsBusy="{Binding EstaOcupado}" BusyContent="Espere, por favor...">
        <Grid Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Canal: " VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Width="130" ItemsSource="{Binding CanalesDisponibles}" SelectedItem="{Binding CanalSeleccionadoNombre}"/>
                <TextBlock Text=" Año: " VerticalAlignment="Center" Margin="10,0,5,0"/>
                <xctk:IntegerUpDown Width="80" Value="{Binding Año}" Minimum="2020" Maximum="2100"/>
                <TextBlock Text=" Mes: " VerticalAlignment="Center" Margin="10,0,5,0"/>
                <xctk:IntegerUpDown Width="60" Value="{Binding Mes}" Minimum="1" Maximum="12"/>
                <Button Content="Descargar facturas" Command="{Binding CargarFacturasCommand}" Margin="10,0,5,0" Padding="10,3"/>
                <Button Content="Contabilizar pendientes" Command="{Binding ContabilizarTodasCommand}" Margin="5,0" Padding="10,3"/>
            </StackPanel>

            <Expander Grid.Row="1" Header="Pegar listado Amazon (Seller Central → Tax Document Library)"
                      IsExpanded="False" Margin="5,0">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding ListadoPegado, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             Height="80" FontFamily="Consolas" FontSize="11"
                             ToolTip="Pega aquí el texto copiado con Ctrl+A/Ctrl+C desde la página de Tax Document Library"/>
                    <Button Grid.Column="1" Content="Emparejar" Command="{Binding EmparejarListadoCommand}"
                            Margin="5,0,0,0" Padding="10,3" VerticalAlignment="Top"/>
                </Grid>
            </Expander>

            <DataGrid Grid.Row="2" ItemsSource="{Binding Facturas}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoFactura}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="NºFactura Amazon" Binding="{Binding InvoiceId, UpdateSourceTrigger=LostFocus}" Width="200"/>
                    <DataGridTextColumn Header="Fecha" Binding="{Binding FechaFactura, StringFormat=d}"/>
                    <DataGridTextColumn Header="Marketplace" Binding="{Binding NombreMarket}"/>
                    <DataGridTextColumn Header="País" Binding="{Binding Pais}"/>
                    <DataGridTextColumn Header="Concepto" Binding="{Binding Concepto}"/>
                    <DataGridTextColumn Header="Base" Binding="{Binding BaseImponible, StringFormat=N2, UpdateSourceTrigger=LostFocus}"/>
                    <DataGridTextColumn Header="CodIVA" Binding="{Binding CodigoIva, UpdateSourceTrigger=LostFocus}"/>
                    <DataGridTextColumn Header="IVA" Binding="{Binding ImporteIva, StringFormat=c}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=c}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Nº Nesto" Binding="{Binding NumeroFacturaNesto}" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Acción" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Contabilizar"
                                        Command="{Binding DataContext.ContabilizarFacturaCommand,
                                                  RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding}"
                                        Padding="5,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Error" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding MensajeError, Mode=OneWay}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         MaxHeight="120"
                                         ToolTip="{Binding MensajeError}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Estado}" Value="YaContabilizada">
                                <Setter Property="Background" Value="LightGray"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Hueco">
                                <Setter Property="Background" Value="#FFFFD6D6"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Contabilizada">
                                <Setter Property="Background" Value="#FFD6FFD6"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Error">
                                <Setter Property="Background" Value="#FFFFCCCC"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <Border Grid.Row="3" Background="#FFF8F8F8" BorderBrush="LightGray" BorderThickness="1" Padding="5" Margin="5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Cuadre mes: " FontWeight="Bold"/>
                    <TextBlock Text="Facturas="/>
                    <TextBlock Text="{Binding TotalContabilizadoMes, StringFormat=c}" Margin="3,0"/>
                    <TextBlock Text=" · Liquidaciones=" Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding TotalLiquidacionesMes, StringFormat=c, TargetNullValue='-'}" Margin="3,0"/>
                    <TextBlock Text=" · Diferencia=" Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding DiferenciaCuadre, StringFormat=c, TargetNullValue='-'}" Margin="3,0" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="4" Text="{Binding MensajeEstado}" Margin="5" FontStyle="Italic"/>
        </Grid>
    </xctk:BusyIndicator>
</UserControl>

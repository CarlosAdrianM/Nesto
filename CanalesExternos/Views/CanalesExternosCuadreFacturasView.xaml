<UserControl x:Class="Nesto.Modulos.CanalesExternos.Views.CanalesExternosCuadreFacturasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900" Language="es-ES">
    <xctk:BusyIndicator IsBusy="{Binding EstaOcupado}" BusyContent="{Binding MensajeProceso}">
        <Grid Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Canal: " VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Width="130" ItemsSource="{Binding CanalesDisponibles}" SelectedItem="{Binding CanalSeleccionadoNombre}"/>
                <TextBlock Text=" Año: " VerticalAlignment="Center" Margin="10,0,5,0"/>
                <xctk:IntegerUpDown Width="80" Value="{Binding Año}" Minimum="2020" Maximum="2100"/>
                <TextBlock Text=" Mes: " VerticalAlignment="Center" Margin="10,0,5,0"/>
                <xctk:IntegerUpDown Width="60" Value="{Binding Mes}" Minimum="1" Maximum="12"/>
                <Button Content="Calcular cuadre" Command="{Binding CalcularCuadreCommand}" Margin="10,0" Padding="10,3"/>
            </StackPanel>

            <TabControl Grid.Row="1" Margin="5">
                <!-- Cuadre de facturas: Amazon ↔ Nesto por InvoiceId (Issue #349 Fase 1) -->
                <TabItem Header="Facturas">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#FFF8F8F8" BorderBrush="LightGray" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="Bold" Text="{Binding CuadreFacturas.Nombre, FallbackValue='Cuadre facturas (sin datos)'}"/>
                                <TextBlock FontSize="12" Foreground="#555">
                                    <Run Text="Cuadradas:"/>
                                    <Run Text="{Binding CuadreFacturas.Cuadrados.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold"/>
                                    <Run Text=" | Solo en Nesto:"/>
                                    <Run Text="{Binding CuadreFacturas.SoloEnNesto.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold" Foreground="#C06000"/>
                                    <Run Text=" | Solo en Amazon:"/>
                                    <Run Text="{Binding CuadreFacturas.SoloEnAmazon.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold" Foreground="#B00020"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Bloque 1: cuadradas -->
                            <Border Grid.Column="0" Margin="0,0,4,0" BorderBrush="#D0D0D0" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#E6F4EA" Padding="6">
                                        <TextBlock FontWeight="Bold" Foreground="#1B5E20">
                                            <Run Text="&#x2713; Cuadradas"/>
                                        </TextBlock>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding FacturasCuadradas}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="InvoiceId" Binding="{Binding Clave}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <!-- Bloque 2: solo en Nesto (Amazon no la reporta) -->
                            <Border Grid.Column="1" Margin="2,0" BorderBrush="#D0D0D0" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#FFF4E5" Padding="6">
                                        <TextBlock FontWeight="Bold" Foreground="#C06000">
                                            <Run Text="&#x26A0; Solo en Nesto"/>
                                        </TextBlock>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding FacturasSoloEnNesto}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="InvoiceId" Binding="{Binding Clave}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <!-- Bloque 3: solo en Amazon (falta contabilizar) -->
                            <Border Grid.Column="2" Margin="4,0,0,0" BorderBrush="#D0D0D0" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#FDECEA" Padding="6">
                                        <TextBlock FontWeight="Bold" Foreground="#B00020">
                                            <Run Text="&#x26A0; Solo en Amazon"/>
                                        </TextBlock>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding FacturasSoloEnAmazon}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="InvoiceId" Binding="{Binding Clave}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Cuadre de pedidos Amazon ↔ Nesto (Issue #349 Fase 3) -->
                <TabItem Header="Pedidos">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#FFF8F8F8" BorderBrush="LightGray" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="Bold" Text="{Binding CuadrePedidos.Nombre, FallbackValue='Cuadre pedidos (sin datos)'}"/>
                                <TextBlock FontSize="12" Foreground="#555">
                                    <Run Text="Cuadrados:"/>
                                    <Run Text="{Binding CuadrePedidos.Cuadrados.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold"/>
                                    <Run Text=" | Solo en Nesto:"/>
                                    <Run Text="{Binding CuadrePedidos.SoloEnNesto.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold" Foreground="#C06000"/>
                                    <Run Text=" | Solo en Amazon:"/>
                                    <Run Text="{Binding CuadrePedidos.SoloEnAmazon.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold" Foreground="#B00020"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,4,0" BorderBrush="#D0D0D0" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#E6F4EA" Padding="6">
                                        <TextBlock FontWeight="Bold" Foreground="#1B5E20">
                                            <Run Text="&#x2713; Cuadrados"/>
                                        </TextBlock>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding PedidosCuadrados}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="AmazonOrderId" Binding="{Binding Clave}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="2,0" BorderBrush="#D0D0D0" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#FFF4E5" Padding="6">
                                        <TextBlock FontWeight="Bold" Foreground="#C06000">
                                            <Run Text="&#x26A0; Solo en Nesto"/>
                                        </TextBlock>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding PedidosSoloEnNesto}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="AmazonOrderId" Binding="{Binding Clave}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="2" Margin="4,0,0,0" BorderBrush="#D0D0D0" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#FDECEA" Padding="6">
                                        <TextBlock FontWeight="Bold" Foreground="#B00020">
                                            <Run Text="&#x26A0; Solo en Amazon"/>
                                        </TextBlock>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding PedidosSoloEnAmazon}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="AmazonOrderId" Binding="{Binding Clave}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Cuadre de liquidaciones Amazon ↔ Nesto (Issue #349 Fase 2) -->
                <TabItem Header="Liquidaciones">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#FFF8F8F8" BorderBrush="LightGray" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="Bold" Text="{Binding CuadreLiquidaciones.Nombre, FallbackValue='Cuadre liquidaciones (sin datos)'}"/>
                                <TextBlock FontSize="12" Foreground="#555">
                                    <Run Text="Cuadradas:"/>
                                    <Run Text="{Binding CuadreLiquidaciones.Cuadrados.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold"/>
                                    <Run Text=" | Solo en Nesto:"/>
                                    <Run Text="{Binding CuadreLiquidaciones.SoloEnNesto.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold" Foreground="#C06000"/>
                                    <Run Text=" | Solo en Amazon:"/>
                                    <Run Text="{Binding CuadreLiquidaciones.SoloEnAmazon.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold" Foreground="#B00020"/>
                                    <Run Text=" | Importes distintos:"/>
                                    <Run Text="{Binding CuadreLiquidaciones.ImportesDistintos.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold" Foreground="#880088"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#555" Margin="0,4,0,0">
                                    <Run Text="Total Nesto:"/>
                                    <Run Text="{Binding CuadreLiquidaciones.TotalImporteNesto, Mode=OneWay, StringFormat=c, FallbackValue='-'}" FontWeight="Bold"/>
                                    <Run Text=" | Total Amazon:"/>
                                    <Run Text="{Binding CuadreLiquidaciones.TotalImporteAmazon, Mode=OneWay, StringFormat=c, FallbackValue='-'}" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Bloque 1: cuadradas -->
                            <Border Grid.Column="0" Margin="0,0,2,0" BorderBrush="#D0D0D0" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#E6F4EA" Padding="6">
                                        <TextBlock FontWeight="Bold" Foreground="#1B5E20">
                                            <Run Text="&#x2713; Cuadradas"/>
                                        </TextBlock>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding LiquidacionesCuadradas}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="EventGroupId" Binding="{Binding Clave}" Width="*"/>
                                            <DataGridTextColumn Header="Importe" Binding="{Binding ImporteAmazon, StringFormat=c}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <!-- Bloque 2: solo en Nesto -->
                            <Border Grid.Column="1" Margin="2,0" BorderBrush="#D0D0D0" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#FFF4E5" Padding="6">
                                        <TextBlock FontWeight="Bold" Foreground="#C06000">
                                            <Run Text="&#x26A0; Solo en Nesto"/>
                                        </TextBlock>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding LiquidacionesSoloEnNesto}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="EventGroupId" Binding="{Binding Clave}" Width="*"/>
                                            <DataGridTextColumn Header="Importe" Binding="{Binding ImporteNesto, StringFormat=c}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <!-- Bloque 3: solo en Amazon -->
                            <Border Grid.Column="2" Margin="2,0" BorderBrush="#D0D0D0" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#FDECEA" Padding="6">
                                        <TextBlock FontWeight="Bold" Foreground="#B00020">
                                            <Run Text="&#x26A0; Solo en Amazon"/>
                                        </TextBlock>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding LiquidacionesSoloEnAmazon}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="EventGroupId" Binding="{Binding Clave}" Width="*"/>
                                            <DataGridTextColumn Header="Importe" Binding="{Binding ImporteAmazon, StringFormat=c}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <!-- Bloque 4: importes distintos -->
                            <Border Grid.Column="3" Margin="2,0,0,0" BorderBrush="#D0D0D0" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#F3E5F5" Padding="6">
                                        <TextBlock FontWeight="Bold" Foreground="#880088">
                                            <Run Text="&#x2260; Importes distintos"/>
                                        </TextBlock>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding LiquidacionesImportesDistintos}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="EventGroupId" Binding="{Binding Clave}" Width="140"/>
                                            <DataGridTextColumn Header="Nesto" Binding="{Binding ImporteNesto, StringFormat=c}"/>
                                            <DataGridTextColumn Header="Amazon" Binding="{Binding ImporteAmazon, StringFormat=c}"/>
                                            <DataGridTextColumn Header="Diferencia" Binding="{Binding Diferencia, Mode=OneWay, StringFormat=c}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Saldo 555 por marketplace (Issue #349 Fase 4 / NestoAPI#164) -->
                <TabItem Header="Saldo 555">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Tabla resumen 22 cuentas -->
                        <Border Grid.Column="0" Margin="0,0,4,0" BorderBrush="#D0D0D0" BorderThickness="1">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#E8EAF6" Padding="6">
                                    <TextBlock FontWeight="Bold" Foreground="#1A237E" Text="Cuentas 555"/>
                                </Border>
                                <DataGrid ItemsSource="{Binding SaldosCuentas555}"
                                          SelectedItem="{Binding CuentaSaldo555Seleccionada, Mode=TwoWay}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" HeadersVisibility="Column"
                                          SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Cuenta" Binding="{Binding Cuenta}" Width="60"/>
                                        <DataGridTextColumn Header="Market" Binding="{Binding NombreMarket}" Width="100"/>
                                        <DataGridTextColumn Header="Concepto" Binding="{Binding Concepto}" Width="60"/>
                                        <DataGridTextColumn Header="Saldo" Binding="{Binding Saldo, StringFormat=c}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="#" Binding="{Binding NumeroAbiertos}" Width="30"/>
                                        <DataGridTextColumn Header="Días" Binding="{Binding DiasMasAntiguo}" Width="40"/>
                                    </DataGrid.Columns>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Saldo}" Value="0">
                                                    <Setter Property="Foreground" Value="#888"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Detalle: grupos abiertos de la cuenta seleccionada -->
                        <Border Grid.Column="1" Margin="4,0,0,0" BorderBrush="#D0D0D0" BorderThickness="1">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#FFF4E5" Padding="6">
                                    <TextBlock FontWeight="Bold" Foreground="#C06000">
                                        <Run Text="Movimientos abiertos"/>
                                        <Run Text="{Binding CuentaSaldo555Seleccionada.Cuenta, Mode=OneWay, FallbackValue=''}"/>
                                        <Run Text="—"/>
                                        <Run Text="{Binding CuentaSaldo555Seleccionada.NombreMarket, Mode=OneWay, FallbackValue=''}"/>
                                        <Run Text="{Binding CuentaSaldo555Seleccionada.Concepto, Mode=OneWay, FallbackValue=''}"/>
                                    </TextBlock>
                                </Border>
                                <DataGrid ItemsSource="{Binding GruposCuentaSeleccionada}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" HeadersVisibility="Column"
                                          RowDetailsVisibilityMode="VisibleWhenSelected">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tipo" Binding="{Binding TipoClave}" Width="100"/>
                                        <DataGridTextColumn Header="Clave" Binding="{Binding Clave}" Width="200"/>
                                        <DataGridTextColumn Header="Saldo" Binding="{Binding Saldo, StringFormat=c}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="1ª fecha" Binding="{Binding FechaPrimerApunte, StringFormat=d}" Width="80"/>
                                        <DataGridTextColumn Header="Días" Binding="{Binding DiasAntiguedad}" Width="50"/>
                                        <DataGridTextColumn Header="# apuntes" Binding="{Binding Apuntes.Count}" Width="70"/>
                                    </DataGrid.Columns>
                                    <DataGrid.RowDetailsTemplate>
                                        <DataTemplate>
                                            <Border Background="#FAFAFA" Padding="4" Margin="20,2,2,2">
                                                <DataGrid ItemsSource="{Binding Apuntes}" AutoGenerateColumns="False"
                                                          IsReadOnly="True" CanUserAddRows="False"
                                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Nº Orden" Binding="{Binding NumeroOrden}" Width="80"/>
                                                        <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=d}" Width="80"/>
                                                        <DataGridTextColumn Header="Concepto" Binding="{Binding Concepto}" Width="*"/>
                                                        <DataGridTextColumn Header="Debe" Binding="{Binding Debe, StringFormat=c}" Width="80"/>
                                                        <DataGridTextColumn Header="Haber" Binding="{Binding Haber, StringFormat=c}" Width="80"/>
                                                        <DataGridTextColumn Header="Doc" Binding="{Binding NumeroDocumento}" Width="100"/>
                                                        <DataGridTextColumn Header="Diario" Binding="{Binding Diario}" Width="80"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Border>
                                        </DataTemplate>
                                    </DataGrid.RowDetailsTemplate>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Cuadre interno Amazon (facturas vs liquidaciones del mes, legacy Fase 0) -->
                <TabItem Header="Totales mes">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#FFF8F8F8" BorderBrush="LightGray" BorderThickness="1" Padding="8" Margin="0,0,0,5">
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="Bold">
                                    <Run Text="Total facturas:"/>
                                    <Run Text="{Binding Cuadre.TotalFacturasContabilizadas, StringFormat=c, FallbackValue='-'}"/>
                                </TextBlock>
                                <TextBlock FontSize="14" FontWeight="Bold">
                                    <Run Text="Total liquidaciones:"/>
                                    <Run Text="{Binding Cuadre.TotalComisionesLiquidaciones, StringFormat=c, FallbackValue='-'}"/>
                                </TextBlock>
                                <TextBlock FontSize="14" FontWeight="Bold">
                                    <Run Text="Diferencia:"/>
                                    <Run Text="{Binding Cuadre.Diferencia, Mode=OneWay, StringFormat=c, FallbackValue='-'}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding DetalleCuadre}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Marketplace" Binding="{Binding NombreMarket}" Width="180"/>
                                <DataGridTextColumn Header="Total facturas" Binding="{Binding TotalFacturas, StringFormat=c}"/>
                                <DataGridTextColumn Header="Total liquidaciones" Binding="{Binding TotalLiquidaciones, StringFormat=c}"/>
                                <DataGridTextColumn Header="Diferencia" Binding="{Binding Diferencia, Mode=OneWay, StringFormat=c}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </xctk:BusyIndicator>
</UserControl>

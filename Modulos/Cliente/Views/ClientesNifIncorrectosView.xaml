<UserControl x:Class="Nesto.Modulos.Cliente.ClientesNifIncorrectosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:controles="clr-namespace:ControlesUsuario;assembly=ControlesUsuario"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="950"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="White">

    <xctk:BusyIndicator IsBusy="{Binding EstaOcupado}" BusyContent="Trabajando...">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Clientes con NIF incorrecto (Verifactu)" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Los clientes con pedido pendiente van primero: su factura se bloqueará si no se corrige."
                           Foreground="DimGray" VerticalAlignment="Center"/>
                <Button Content="Actualizar" Command="{Binding CargarCommand}" Margin="15,0,0,0" Padding="10,2"/>
            </StackPanel>

            <DataGrid Grid.Row="2" ItemsSource="{Binding Clientes}" AutoGenerateColumns="False"
                      SelectedItem="{Binding ClienteSeleccionado}"
                      CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single" ColumnWidth="Auto">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <!-- Prioritarios: pedido pendiente de servir o facturar -->
                            <DataTrigger Binding="{Binding TienePedidoPendiente}" Value="True">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Background" Value="#FFF4E5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Pedido pdte." Binding="{Binding TienePedidoPendiente}"/>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente}"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="NIF actual" Binding="{Binding Nif}"/>
                    <DataGridTextColumn Header="Respuesta AEAT" Binding="{Binding ResultadoAeat}"/>
                    <DataGridTextColumn Header="Detectado" Binding="{Binding FechaValidacion, StringFormat=d}"/>
                    <DataGridTextColumn Header="Vendedor" Binding="{Binding Vendedor}"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="3" BorderBrush="LightGray" BorderThickness="0,1,0,0" Margin="0,10,0,0" Padding="0,10,0,0">
                <StackPanel>
                    <!-- NIF correcto: común a los dos caminos (para el extranjero es opcional, si el
                         que hay ya es bueno). -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="NIF correcto:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
                        <TextBox Text="{Binding NifNuevo, UpdateSourceTrigger=PropertyChanged}" MinWidth="160"
                                 VerticalContentAlignment="Center" CharacterCasing="Upper"/>
                        <TextBlock Text="Escribe el NIF correcto y elige UNA opción según de dónde sea el cliente:"
                                   Foreground="DimGray" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    </StackPanel>

                    <!-- Camino ESPAÑOL: se valida contra la AEAT. Se deshabilita si indicas país. -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Cliente español" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"
                                   Width="130"/>
                        <Button Content="Corregir NIF" Command="{Binding CorregirCommand}" Padding="10,2" FontWeight="Bold" MinWidth="140"/>
                        <TextBlock Text="Valida el NIF contra la AEAT y actualiza ficha, contactos y facturas sin declarar."
                                   Foreground="DimGray" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    </StackPanel>

                    <!-- Camino EXTRANJERO (NestoAPI#339/#354): tipo + país, sin censo, IDOtro. -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Cliente extranjero" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"
                                   Width="130"/>
                        <TextBlock Text="Tipo:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox ItemsSource="{Binding TiposIdentificacion}" SelectedItem="{Binding TipoIdentificacionSeleccionado}"
                                  DisplayMemberPath="Descripcion" MinWidth="190" VerticalContentAlignment="Center"/>
                        <TextBlock Text="País:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <controles:SelectorPais Seleccionado="{Binding PaisIdentificacion, Mode=TwoWay}"
                                                VisibilidadEtiqueta="Collapsed" Width="180" VerticalAlignment="Center"/>
                        <Button Content="Marcar como extranjero" Command="{Binding MarcarExtranjeroCommand}" Margin="10,0,0,0" Padding="10,2" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock Text="El cliente extranjero no se valida contra el censo español; su factura se declara a Verifactu con ese tipo y país. Los de la UE se declaran solos por su país."
                               Foreground="DimGray" TextWrapping="Wrap" Margin="138,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </xctk:BusyIndicator>
</UserControl>

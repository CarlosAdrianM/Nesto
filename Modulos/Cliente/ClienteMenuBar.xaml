<UserControl x:Class="Nesto.Modulos.Cliente.ClienteMenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Nesto.Modulos.Cliente"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Ribbon x:Name="MainMenu" x:FieldModifier="protected internal">
        <RibbonTab x:Name="tabClientes"
                            Header="Clientes">
            <RibbonGroup x:Name="grpMantenimiento"
                                Header="Mantenimiento">
                <RibbonButton Label="Crear Cliente" LargeImageSource="Images/crear_cliente.png" Command="{Binding AbrirModuloCommand}" />
                <!-- Nesto#417: corrección rápida de NIF incorrectos (Verifactu) -->
                <RibbonButton Label="NIF incorrectos" LargeImageSource="Images/crear_cliente.png" Command="{Binding AbrirNifIncorrectosCommand}" />
            </RibbonGroup>
            <RibbonGroup x:Name="grpDocumentos"
                                Header="Documentos">
                <RibbonButton Label="Modelo 347" LargeImageSource="Images/crear_cliente.png" Command="{Binding AbrirModelo347Command}" />
            </RibbonGroup>
            <RibbonGroup x:Name="grpCartera"
                                Header="Cartera">
                <RibbonButton Label="Extracto Cliente" LargeImageSource="Images/crear_cliente.png" Command="{Binding AbrirExtractoClienteCommand}" />
            </RibbonGroup>
        </RibbonTab>
    </Ribbon>
</UserControl>
